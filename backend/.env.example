# Copy this to .env and fill in values

# Required
JWT_SECRET=change-this-to-a-long-random-string

# Server
PORT=3001

# Database path
# Local dev: leave unset (uses backend/yummara.db)
# Railway: set to /data/yummara.db after adding a Volume in the dashboard
# DB_PATH=/data/yummara.db

# CORS: comma-separated list of frontend origins
# Add your Vercel URL here after deploying the frontend
# CORS_ORIGINS=https://yummara.vercel.app,http://localhost:5173

# WhatsApp Cloud API (Meta) — primary OTP channel
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=yummara_otp

# MSG91 SMS (fallback)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=YUMMARA
MSG91_TEMPLATE_ID=

# Dev only — shows OTP in API response. Set to false or remove in production.
DEV_OTP=true
